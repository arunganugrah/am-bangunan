rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: cek apakah user adalah admin
    function isAdmin() {
      return request.auth != null &&
             request.auth.token.email == 'admin@ambangunan.com';
    }

    // Helper: cek apakah user sudah login
    function isLoggedIn() {
      return request.auth != null;
    }

    // Produk/stok: semua karyawan bisa baca & tambah; hanya admin bisa ubah harga
    match /produk/{id} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Kategori produk: hanya admin
    match /kategori/{id} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    // Transaksi: semua karyawan bisa baca & tulis (kasir)
    match /transaksi/{id} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn();
      allow update, delete: if isAdmin();
    }

    // Pembelian stok (uang keluar): hanya admin
    match /pembelian_stok/{id} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Karyawan: hanya admin
    match /karyawan/{id} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Pengaturan toko: hanya admin
    match /pengaturan/{id} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }
  }
}
